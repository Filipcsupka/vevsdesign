<script>
  const packageCards = document.querySelectorAll('.balik-card[data-detail]');
  const packageModal = document.getElementById('balik-modal');
  const packageModalContent = document.getElementById('balik-modal-content');
  const packageModalCta = document.getElementById('balik-modal-cta');
  const packageModalClose = packageModal.querySelector('.balik-modal-close');
  const packageSelect = document.querySelector('select[name="balik"]');
  let lastFocusedCard = null;

  function closePackageModal() {
    packageModal.hidden = true;
    document.body.classList.remove('modal-open');
    packageModalContent.innerHTML = '';
    if (lastFocusedCard) lastFocusedCard.focus();
  }

  function openPackageModal(card) {
    const detailId = card.dataset.detail;
    const detailTemplate = document.getElementById(detailId);
    if (!detailTemplate) return;

    lastFocusedCard = card;
    packageModalContent.innerHTML = detailTemplate.innerHTML;
    const modalTitle = packageModalContent.querySelector('.balik-modal-name');
    if (modalTitle) modalTitle.id = 'balik-modal-name';
    packageModalCta.dataset.package = card.dataset.package || '';
    packageModal.hidden = false;
    document.body.classList.add('modal-open');
    packageModalClose.focus();
  }

  packageCards.forEach((card) => {
    card.addEventListener('click', () => openPackageModal(card));
    card.addEventListener('keydown', (event) => {
      if (event.key === 'Enter' || event.key === ' ') {
        event.preventDefault();
        openPackageModal(card);
      }
    });
  });

  packageModal.addEventListener('click', (event) => {
    if (event.target.hasAttribute('data-close-modal')) closePackageModal();
  });

  packageModalCta.addEventListener('click', () => {
    const selectedPackage = packageModalCta.dataset.package;
    if (packageSelect && selectedPackage) packageSelect.value = selectedPackage;
    closePackageModal();
  });

  document.addEventListener('keydown', (event) => {
    if (!packageModal.hidden && event.key === 'Escape') closePackageModal();
  });
</script>

</body>
</html>
