{
  "name": "vevsdesign",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "node --localstorage-file=/tmp/vevsdesign-localstorage.json ./node_modules/next/dist/bin/next dev --hostname 127.0.0.1 --port 3000",
